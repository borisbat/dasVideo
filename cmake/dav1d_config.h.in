/* dav1d config.h — generated by dasVideo's CMake (BuildDav1d.cmake), NOT meson.
 * Matches `meson setup -Denable_asm=false` output 1:1 (the validated C-only set).
 * HAVE_ASM is always 0, so no arch dispatch / nasm; ARCH_* stay accurate for the
 * few C-core checks. The HAVE_AS_* / DOTPROD / SVE flags are asm-only -> all 0. */
#pragma once

/* bitdepths (both compiled) + logging */
#define CONFIG_8BPC 1
#define CONFIG_16BPC 1
#define CONFIG_LOG 1
#define CONFIG_MACOS_KPERF 0

/* C-only: no assembly, DSP tables trimmed (meson sets TRIM=1 when asm is off) */
#define HAVE_ASM 0
#define TRIM_DSP_FUNCTIONS 1

/* asm/arch-ext probes — irrelevant under HAVE_ASM=0, kept 0 to match meson */
#define HAVE_AS_FUNC 0
#define HAVE_AS_ARCH_DIRECTIVE 0
#define HAVE_AS_ARCHEXT_DOTPROD_DIRECTIVE 0
#define HAVE_AS_ARCHEXT_I8MM_DIRECTIVE 0
#define HAVE_AS_ARCHEXT_SVE_DIRECTIVE 0
#define HAVE_AS_ARCHEXT_SVE2_DIRECTIVE 0
#define HAVE_DOTPROD 0
#define HAVE_I8MM 0
#define HAVE_SVE 0
#define HAVE_SVE2 0

#define ENDIANNESS_BIG @DAV1D_ENDIANNESS_BIG@

/* architecture */
#define ARCH_AARCH64    @DAV1D_ARCH_AARCH64@
#define ARCH_ARM        @DAV1D_ARCH_ARM@
#define ARCH_X86        @DAV1D_ARCH_X86@
#define ARCH_X86_64     @DAV1D_ARCH_X86_64@
#define ARCH_X86_32     @DAV1D_ARCH_X86_32@
#define ARCH_PPC64LE    0
#define ARCH_RISCV      0
#define ARCH_RV32       0
#define ARCH_RV64       0
#define ARCH_LOONGARCH  0
#define ARCH_LOONGARCH32 0
#define ARCH_LOONGARCH64 0

/* allocation */
#define HAVE_POSIX_MEMALIGN @DAV1D_HAVE_POSIX_MEMALIGN@
#define HAVE_MEMALIGN       @DAV1D_HAVE_MEMALIGN@
#define HAVE_ALIGNED_ALLOC  @DAV1D_HAVE_ALIGNED_ALLOC@

/* platform features */
#define HAVE_CLOCK_GETTIME  @DAV1D_HAVE_CLOCK_GETTIME@
#define HAVE_DLSYM          @DAV1D_HAVE_DLSYM@
#define HAVE_GETAUXVAL      0
#define HAVE_ELF_AUX_INFO   0
#define HAVE_SYS_TYPES_H    @DAV1D_HAVE_SYS_TYPES_H@
#define HAVE_UNISTD_H       @DAV1D_HAVE_UNISTD_H@
#define HAVE_IO_H           @DAV1D_HAVE_IO_H@
#define HAVE_C11_GENERIC    @DAV1D_HAVE_C11_GENERIC@

/* threading (pthread niceties; 0 just drops affinity/naming) */
#define HAVE_PTHREAD_GETAFFINITY_NP @DAV1D_HAVE_PTHREAD_GETAFFINITY_NP@
#define HAVE_PTHREAD_SETAFFINITY_NP @DAV1D_HAVE_PTHREAD_SETAFFINITY_NP@
#define HAVE_PTHREAD_SETNAME_NP     @DAV1D_HAVE_PTHREAD_SETNAME_NP@
#define HAVE_PTHREAD_SET_NAME_NP    0
#define HAVE_PTHREAD_NP_H           0

@DAV1D_WIN32_CONFIG@
