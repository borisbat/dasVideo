# build dirs
_build/
build/
out/

# decode-backend sources: FetchContent'd at build time (pinned), never committed
vendor/dav1d/
vendor/nestegg/
vendor/opus/

# native module artifacts
*.shared_module
*.lib
*.exp
*.pdb
*.ilk
*.obj
*.o
*.so
*.dylib

# runtime / scratch
*.log
_smoke_*.das

# tutorial recording intermediates (manual, local-only): only the committed .mp4 and
# the record_*.das driver are tracked — the APNG / music bed / voiceover wavs are scratch
tutorials/**/recording/*.apng
tutorials/**/recording/*.wav
tutorials/**/recording/voiceover/
*.mp4.ffmpeg.txt

# docs build artifacts
__pycache__/
*.pyc
_site/
doc/build/
# tutorial recordings copied in by conf.py (source mp4s live in tutorials/<name>/)
doc/source/_static/tutorials/

# daspkg install dir + lockfile (created by `daspkg install`)
modules/
daspkg.lock
